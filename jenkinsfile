pipeline {
	agent any

	stages {
	
		stage('workspace cleanup') {
			steps {
				cleanws()
			}
		}
	
		stage('checkout') {
			steps {
				checkout scm
			}
		}

		stage('environment check') {
			steps {
				sh 'whoami'
				sh 'pwd'
				sh 'java -version'
				sh 'docker --version'
                		sh 'aws --version'
                		sh 'kubectl version --client'
                		sh 'helm version' 	
				}
        	}	
 

	post {
		always {
			echo 'Pipeline completed'
		}
	}
}
