pipeline {
    agent any

    stages {

        stage('Workspace Cleanup') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Environment Check') {
            steps {
                sh 'whoami'
                sh 'pwd'
                sh 'java -version'
                sh 'git --version'
                sh 'docker --version'
                sh 'aws --version'
                sh 'kubectl version --client'
                sh 'helm version'
            }
        }
	
        stage('Build Docker Image') {
	    steps {
		sh 'docker build -t trend-app:latest .'
	    }
	}
    }

    post {
        always {
            echo 'Pipeline completed.'
        }
    }
}
